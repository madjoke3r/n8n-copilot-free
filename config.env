# ─────────────────────────────────────────────────────────────────
# n8n-copilot-free  —  Port & version configuration
# Edit these before running setup.sh
# setup.sh will auto-find the next available port if one is in use.
# ─────────────────────────────────────────────────────────────────

# ── Ports ────────────────────────────────────────────────────────
N8N_PORT=5678           # n8n web UI — change if 5678 is already in use
COPILOT_API_PORT=4141   # copilot-api OpenAI-compat endpoint
COPILOT_SHIM_PORT=4142  # Responses-API shim (what n8n credentials point to)

# ── copilot-api version ───────────────────────────────────────────
# Pin to a known-good version. Check https://github.com/ericc-ch/copilot-api for updates.
COPILOT_API_VERSION=0.7.0

# ── Database ──────────────────────────────────────────────────────
DB_USER=n8n
DB_PASSWORD=changeme123        # CHANGE THIS before going to production
DB_NAME=n8n

# ── n8n domain / URL ─────────────────────────────────────────────
# These should match however you already access your n8n instance.
# If behind a reverse proxy (Apache, Nginx, Caddy, etc.), use that URL.
# If accessed directly: http://YOUR_SERVER_IP:5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678/webhook

# ── n8n secrets ───────────────────────────────────────────────────
# Leave blank to auto-generate secure random values during setup.
N8N_ENCRYPTION_KEY=
JWT_SECRET=
ADMIN_PASSWORD=Change@Me123

# ── SSL (optional) ────────────────────────────────────────────────
# If n8n needs to serve HTTPS directly (e.g. pfSense routes TLS
# straight to this port), set paths to your cert and key files.
# Leave blank to run plain HTTP (most users behind a reverse proxy).
N8N_SSL_CERT=
N8N_SSL_KEY=
N8N_SECURE_COOKIE=false
